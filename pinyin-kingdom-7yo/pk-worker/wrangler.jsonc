{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pinyin-kingdom-pk",
  "main": "src/index.js",
  "compatibility_date": "2026-07-22",
  "durable_objects": {
    "bindings": [
      {
        "name": "PK_ROOMS",
        "class_name": "PKRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PKRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
